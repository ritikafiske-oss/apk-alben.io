#!/bin/bash

BRANCH=$(git rev-parse --abbrev-ref HEAD)

echo "Checking branch status before push..."

git fetch origin

REMOTE_BRANCH="origin/$BRANCH"

# Allow first push of a new branch
if ! git show-ref --verify --quiet refs/remotes/$REMOTE_BRANCH; then
    echo "✅ New branch detected. First push allowed."
    exit 0
fi

LOCAL=$(git rev-parse HEAD)
REMOTE=$(git rev-parse $REMOTE_BRANCH)

if [ "$LOCAL" != "$REMOTE" ]; then
    echo ""
    echo "❌ Push blocked!"
    echo "Your branch is not updated with $REMOTE_BRANCH"
    echo ""
    echo "Please run:"
    echo "git pull origin $BRANCH"
    echo ""
    echo "Resolve conflicts if required, then push again."
    exit 1
fi

echo "✅ Branch is synchronized. Push allowed."

exit 0
