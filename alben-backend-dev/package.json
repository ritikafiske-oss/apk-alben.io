{
  "name": "alben-backend",
  "version": "0.0.1",
  "description": "Backend API for the Alben project, built as a Modular Monolith using the NestJS framework.",
  "author": "SelfTech Solutions Pvt Ltd",
  "private": true,
  "license": "UNLICENSED",
  "scripts": {
    "build": "nest build",
    "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\" \"libs/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.ts\" \"test/**/*.ts\" \"libs/**/*.ts\"",
    "start": "nest start",
    "start:dev": "nest start --watch",
    "start:debug": "nest start --debug --watch",
    "start:prod": "node dist/main",
    "lint": "eslint \"{src,apps,libs,test}/**/*.ts\"",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage",
    "test:debug": "node --inspect-brk -r tsconfig-paths/register -r ts-node/register node_modules/.bin/jest --runInBand",
    "test:e2e": "jest --config ./test/jest-e2e.json",
    "typeorm": "typeorm-ts-node-commonjs",
    "migration:create": "typeorm-ts-node-commonjs migration:create",
    "migration:run": "node -r ts-node/register -r tsconfig-paths/register ./node_modules/typeorm/cli.js migration:run -d src/infrastructure/persistence/data-source.ts",
    "migration:revert": "node -r ts-node/register -r tsconfig-paths/register ./node_modules/typeorm/cli.js migration:revert -d src/infrastructure/persistence/data-source.ts",
    "migration:show": "node -r ts-node/register -r tsconfig-paths/register ./node_modules/typeorm/cli.js migration:show -d src/infrastructure/persistence/data-source.ts",
    "migration:generate": "node -r ts-node/register -r tsconfig-paths/register ./node_modules/typeorm/cli.js migration:generate -d src/infrastructure/persistence/data-source.ts"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1037.0",
    "@nestjs/common": "^11.1.19",
    "@nestjs/config": "^4.0.3",
    "@nestjs/core": "^11.1.19",
    "@nestjs/jwt": "^11.0.2",
    "@nestjs/passport": "^11.0.5",
    "@nestjs/platform-express": "^11.1.19",
    "@nestjs/swagger": "^11.4.1",
    "@nestjs/terminus": "^11.1.1",
    "@nestjs/typeorm": "^11.0.1",
    "@types/bcrypt": "^6.0.0",
    "@types/passport-jwt": "^4.0.1",
    "bcrypt": "^6.0.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.3",
    "dayjs": "^1.11.19",
    "express-basic-auth": "^1.2.1",
    "mysql2": "^3.17.0",
    "nest-winston": "^1.10.2",
    "nodemailer": "^8.0.5",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "typeorm": "^0.3.28",
    "uuid": "^14.0.0",
    "winston": "^3.19.0",
    "winston-daily-rotate-file": "^5.0.0"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.2.0",
    "@eslint/js": "^9.18.0",
    "@nestjs/cli": "^11.0.21",
    "@nestjs/schematics": "^11.1.0",
    "@nestjs/testing": "^11.1.19",
    "@types/express": "^5.0.0",
    "@types/jest": "^30.0.0",
    "@types/node": "^22.10.7",
    "@types/nodemailer": "^8.0.0",
    "@types/supertest": "^6.0.2",
    "dotenv": "^16.4.7",
    "eslint": "^9.18.0",
    "eslint-config-prettier": "^10.0.1",
    "eslint-plugin-prettier": "^5.2.2",
    "globals": "^16.0.0",
    "jest": "^30.0.0",
    "jsonwebtoken": "^9.0.3",
    "prettier": "^3.4.2",
    "source-map-support": "^0.5.21",
    "supertest": "^7.0.0",
    "ts-jest": "^29.4.9",
    "ts-loader": "^9.5.2",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.20.0"
  },
  "jest": {
    "moduleFileExtensions": [
      "js",
      "json",
      "ts"
    ],
    "rootDir": ".",
    "testRegex": ".*\\.spec\\.ts$",
    "transform": {
      "^.+\\.(t|j)s$": "ts-jest"
    },
    "collectCoverageFrom": [
      "**/*.(t|j)s"
    ],
    "coverageDirectory": "./coverage",
    "testEnvironment": "node",
    "roots": [
      "<rootDir>/src/",
      "<rootDir>/libs/"
    ],
    "moduleNameMapper": {
      "^@app/localization(|/.*)$": "<rootDir>/libs/localization/src/$1",
      "^@libs/authentication$": "<rootDir>/libs/authentication/index",
      "^@libs/common$": "<rootDir>/libs/common/index",
      "^@libs/contact-status$": "<rootDir>/libs/contact-status/index",
      "^@libs/contacts$": "<rootDir>/libs/contacts/index",
      "^@libs/dashboard$": "<rootDir>/libs/dashboard/index",
      "^@libs/health$": "<rootDir>/libs/health/index",
      "^@libs/localization$": "<rootDir>/libs/localization/index",
      "^@libs/notes$": "<rootDir>/libs/notes/index",
      "^@libs/notifications$": "<rootDir>/libs/notifications/index",
      "^@libs/products$": "<rootDir>/libs/products/index",
      "^@libs/services$": "<rootDir>/libs/services/index",
      "^@libs/storage$": "<rootDir>/libs/storage/index",
      "^@libs/users$": "<rootDir>/libs/users/index",
      "^@libs/reports$": "<rootDir>/libs/reports/index",
      "^@libs/visits$": "<rootDir>/libs/visits/index",
      "^@libs/locations$": "<rootDir>/libs/locations/index"
    }
  },
  "pnpm": {
    "overrides": {
      "fast-xml-parser": "^5.7.0",
      "uuid": "^14.0.0",
      "lodash": "^4.18.0",
      "minimatch": "^9.0.7",
      "brace-expansion": "^2.0.3",
      "ajv": "^8.18.0",
      "eslint>ajv": "6.14.0",
      "@eslint/eslintrc>ajv": "6.14.0",
      "picomatch": "^4.0.4",
      "flatted": "^3.4.2"
    }
  }
}